@{
    ViewData["Title"] = "داشبورد";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

<div class="row g-4 mb-4">
    <!-- Total Products -->
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card p-4" style="background: linear-gradient(135deg, #1976d2, #42a5f5);">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="number">@ViewBag.TotalProducts</div>
                    <div class="mt-1 opacity-75">کل محصولات</div>
                </div>
                <span style="font-size:2.5rem;">📦</span>
            </div>
        </div>
    </div>

    <!-- Total Categories -->
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card p-4" style="background: linear-gradient(135deg, #388e3c, #66bb6a);">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="number">@ViewBag.TotalCategories</div>
                    <div class="mt-1 opacity-75">دسته‌بندی‌ها</div>
                </div>
                <span style="font-size:2.5rem;">🗂️</span>
            </div>
        </div>
    </div>

    <!-- Total Orders -->
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card p-4" style="background: linear-gradient(135deg, #f57c00, #ffa726);">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="number">@ViewBag.TotalOrders</div>
                    <div class="mt-1 opacity-75">کل سفارش‌ها</div>
                </div>
                <span style="font-size:2.5rem;">🛒</span>
            </div>
        </div>
    </div>

    <!-- Pending Orders -->
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card p-4" style="background: linear-gradient(135deg, #c62828, #ef5350);">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="number">@ViewBag.PendingOrders</div>
                    <div class="mt-1 opacity-75">سفارش‌های در انتظار</div>
                </div>
                <span style="font-size:2.5rem;">⏳</span>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white fw-bold">دسترسی سریع</div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4">
                <a asp-action="CreateProduct" class="btn btn-primary w-100 py-3 rounded-3">
                    ➕ افزودن محصول جدید
                </a>
            </div>
            <div class="col-md-4">
                <a asp-action="CreateCategory" class="btn btn-success w-100 py-3 rounded-3">
                    ➕ افزودن دسته‌بندی جدید
                </a>
            </div>
            <div class="col-md-4">
                <a asp-action="Orders" class="btn btn-warning w-100 py-3 rounded-3">
                    👁️ مشاهده سفارش‌ها
                </a>
            </div>
        </div>
    </div>
</div>

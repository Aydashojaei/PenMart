@model ProductDetailsViewModel

<div class="container my-5">

    <div class="row g-4 align-items-start">

        <!-- ستون سایدبار -->
        <div class="col-12 col-md-3">
            <div class="sidebar shadow-sm p-3 rounded">
                @await Component.InvokeAsync("ProductCategoryComponent", new { view = "CategorySidebar" })
            </div>
        </div>

        <!-- ستون اسلایدر -->
        <div class="col-12 col-md-5">
            <div class="image-box shadow-sm rounded p-3" style="background:#f7f7f7;">

                <!-- اسلایدر Bootstrap 4 -->
                <div id="productSlider" class="carousel slide" data-ride="carousel">

                    <div class="carousel-inner">

                        @for (int i = 0; i < Model.Images.Count; i++)
                        {
                            <div class="carousel-item @(i == 0 ? "active" : "") text-center">
                                <img src="/@Model.Images[i].Url"
                                     class="d-block w-100 product-image"
                                     style="max-height:350px; object-fit:contain;" />
                            </div>
                        }

                    </div>

                    <!-- دکمه قبلی -->
                    <a class="carousel-control-prev" href="#productSlider" role="button" data-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    </a>

                    <!-- دکمه بعدی -->
                    <a class="carousel-control-next" href="#productSlider" role="button" data-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    </a>

                </div>

            </div>
        </div>

        <!-- ستون توضیحات -->
        <div class="col-12 col-md-4">
            <div class="product-info card shadow-sm p-4">

                @if (Model.Product.Category != null)
                {
                    <span class="badge badge-info mb-3 p-2">@Model.Product.Category.CategoryName</span>
                }

                <h3 class="fw-bold mb-3">@Model.Product.Name</h3>

                <p class="h5 text-success fw-bold">
                    @Model.Item.Price.ToString("N0") تومان
                </p>

                <p class="text-muted mt-2">@Model.Product.Discription</p>

                <a 
                    asp-controller="Cart"
                    asp-action="AddToCart"
                   asp-route-Id="@Model.Product.Id"
                   class="btn btn-primary w-100 mt-4">
                    افزودن به سبد خرید 🛒
                </a>
            </div>
        </div>

    </div>

</div>

<style>
    .product-image {
        width: 100%;
        max-height: 350px;
        object-fit: contain;
    }

    .sidebar {
        background: #ffffff;
        border: 1px solid #eee;
        border-radius: 15px;
    }

    .product-info {
        border-radius: 15px;
        background: #ffffff;
    }
</style>

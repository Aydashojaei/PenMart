@model ProductDetailsViewModel
@{
    ViewData["Title"] = Model.Product.Name;
}

<div class="container my-5">
    <div class="row g-4 align-items-start">

        <!-- سایدبار -->
        <div class="col-12 col-md-3 d-none d-md-block">
            <div class="sidebar-box p-3 rounded-4">
                @await Component.InvokeAsync("ProductCategoryComponent", new { view = "CategorySidebar" })
            </div>
        </div>

        <!-- گالری تصاویر -->
        <div class="col-12 col-md-4">
            <div class="gallery-box rounded-4 p-3">
                <!-- تصویر اصلی -->
                <div class="main-img-wrap mb-3">
                    <img id="mainImg"
                         src="@Url.Content(Model.Images.FirstOrDefault(i => i.IsMain)?.Url ?? Model.Images.FirstOrDefault()?.Url)"
                         alt="@Model.Product.Name"
                         class="main-img" />
                </div>

                <!-- تامبنیل‌ها -->
                @if (Model.Images.Count > 1)
                {
                    <div class="d-flex gap-2 flex-wrap">
                        @foreach (var img in Model.Images)
                        {
                            <div class="thumb-wrap @(img.IsMain ? "active" : "")"
                                 onclick="switchImage(this, '@Url.Content(img.Url)')">
                                <img src="@Url.Content(img.Url)" alt="تصویر محصول" class="thumb-img" />
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- اطلاعات محصول -->
        <div class="col-12 col-md-5">
            <div class="info-box rounded-4 p-4">

                <!-- دسته‌بندی -->
                @if (Model.Product.Category != null)
                {
                    <span class="category-badge mb-3 d-inline-block">
                        @Model.Product.Category.CategoryName
                    </span>
                }

                <!-- نام -->
                <h3 class="fw-bold text-dark mb-3">@Model.Product.Name</h3>

                <!-- قیمت -->
                <div class="price-box mb-3">
                    <span class="price-label">قیمت:</span>
                    <span class="price-value">@Model.Item.Price.ToString("N0") تومان</span>
                </div>

                <!-- موجودی -->
                <div class="stock-box mb-3">
                    @if (Model.Item.QuantityInStock > 0)
                    {
                        <span class="badge-stock-ok">✅ موجود در انبار (@Model.Item.QuantityInStock عدد)</span>
                    }
                    else
                    {
                        <span class="badge-stock-out">❌ ناموجود</span>
                    }
                </div>

                <!-- توضیحات -->
                <div class="desc-box mb-4">
                    <p class="text-muted">@Model.Product.Discription</p>
                </div>

                <!-- دکمه سبد خرید -->
                @if (Model.Item.QuantityInStock > 0)
                {
                    <a asp-controller="Cart"
                       asp-action="AddToCart"
                       asp-route-Id="@Model.Product.Id"
                       class="btn-add-cart w-100">
                        🛒 افزودن به سبد خرید
                    </a>
                }
                else
                {
                    <button class="btn-add-cart w-100 disabled" disabled>
                        موجودی ندارد
                    </button>
                }

            </div>
        </div>

    </div>
</div>

<style>
    .sidebar-box {
        background: #fff;
        border: 1px solid #eee;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        position: sticky;
        top: 90px;
    }

    .gallery-box {
        background: #f8f9fb;
        border: 1px solid #eee;
    }

    .main-img-wrap {
        display: flex;
        align-items: center;
        justify-content: center;
        height: 280px;
        background: white;
        border-radius: 12px;
        overflow: hidden;
    }

    .main-img {
        max-height: 260px;
        object-fit: contain;
        transition: transform 0.3s ease;
    }

    .thumb-wrap {
        width: 64px;
        height: 64px;
        border-radius: 8px;
        overflow: hidden;
        border: 2px solid transparent;
        cursor: pointer;
        transition: border-color 0.2s;
        background: white;
    }

    .thumb-wrap.active, .thumb-wrap:hover {
        border-color: #4a90e2;
    }

    .thumb-img {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    .info-box {
        background: #fff;
        border: 1px solid #eee;
        box-shadow: 0 2px 16px rgba(0,0,0,0.07);
    }

    .category-badge {
        background: #e8f4fd;
        color: #1a73e8;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.85rem;
    }

    .price-box {
        background: #f0faf3;
        border-radius: 10px;
        padding: 12px 16px;
    }

    .price-label {
        color: #555;
        font-size: 0.9rem;
    }

    .price-value {
        font-size: 1.5rem;
        font-weight: bold;
        color: #2e7d32;
        margin-right: 8px;
    }

    .badge-stock-ok {
        background: #e8f5e9;
        color: #2e7d32;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 0.85rem;
    }

    .badge-stock-out {
        background: #fdecea;
        color: #c62828;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 0.85rem;
    }

    .desc-box {
        background: #fafafa;
        border-right: 3px solid #4a90e2;
        padding: 12px 16px;
        border-radius: 0 8px 8px 0;
        line-height: 1.8;
    }

    .btn-add-cart {
        display: block;
        background: linear-gradient(135deg, #1976d2, #42a5f5);
        color: white;
        border: none;
        padding: 14px;
        border-radius: 12px;
        font-size: 1rem;
        font-weight: bold;
        text-align: center;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .btn-add-cart:hover:not(.disabled) {
        background: linear-gradient(135deg, #1565c0, #1e88e5);
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(25,118,210,0.35);
    }

    .btn-add-cart.disabled {
        background: #ccc;
        cursor: not-allowed;
    }
</style>

@section Scripts {
    <script>
        function switchImage(el, url) {
            document.getElementById('mainImg').src = url;
            document.querySelectorAll('.thumb-wrap').forEach(t => t.classList.remove('active'));
            el.classList.add('active');
        }
    </script>
}

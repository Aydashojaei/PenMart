@model IEnumerable<ProductViewModel>
@{
    ViewData["Title"] = ViewData["CategoryName"];
}

<h2 class="text-center mt-4 mb-4 fw-bold">
    محصولات گروه @ViewData["CategoryName"]
</h2>

<div class="container">
    <div class="row">

        <!-- سایدبار -->
        <div class="col-12 col-md-3 mb-4">
            <div class="sidebar shadow-sm p-3 rounded position-sticky" style="top: 100px;">
                @await Component.InvokeAsync("ProductCategoryComponent", new { view = "CategorySidebar" })
            </div>
        </div>

        <!-- گرید محصولات -->
        <div class="col-12 col-md-9">
            <div class="row g-4">

                @foreach (var item in Model)
                {
                    <div class="col-6 col-md-4 col-lg-3">
                        <div class="card product-card shadow-sm border-0 rounded-4">
                            <div class="p-3 text-center">
                                <img src="@item.Url" class="card-img-top rounded-3"
                                     alt="@item.Name"
                                     style="height: 170px; object-fit: contain;">
                            </div>

                            <div class="card-body text-center">
                                <h6 class="fw-bold text-dark">@item.Name</h6>

                                <p class="text-muted mb-2 small">
                                    قیمت:
                                    <span class="fw-bold text-success">@item.Price.ToString("N0") تومان</span>
                                </p>

                                <a asp-controller="Product"
                                   asp-action="ShowProductDetails"
                                   asp-route-id="@item.Id"
                                   class="btn btn-primary btn-sm rounded-pill px-3">
                                    جزئیات
                                </a>

                            </div>
                        </div>
                    </div>
                }

            </div>
        </div>

    </div>
</div>

<style>
    .product-card {
        background-color: #fffaf4;
        border-radius: 12px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.08);
        transition: .25s;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

        .product-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        }

    .product-image-box {
        height: 180px;
        display: flex;
        align-items: center;
        justify-content: center;
    }


</style>


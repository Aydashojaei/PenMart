@model IEnumerable<ProductViewModel>
@{
    ViewData["title"] = "همه ی محصولات";
}

<div class="container my-5">
    <div class="row">

        <!-- سایدبار -->
        <div class="col-12 col-md-3 mb-4">
            <div class="sidebar-box p-3 rounded-4 position-sticky" style="top: 90px;">
                @await Component.InvokeAsync("ProductCategoryComponent", new { view = "CategorySidebar" })
            </div>
        </div>

        <!-- بخش اصلی -->
        <div class="col-12 col-md-9">

            <!-- هدر -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h4 class="fw-bold mb-0">@ViewData["CategoryName"]</h4>
                    <small class="text-muted">@Model.Count() محصول</small>
                    <h4>همه ی محصولات </h4>
                </div>
            </div>

            <!-- گرید محصولات -->
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <span style="font-size:4rem;">📦</span>
                    <p class="text-muted mt-3">محصولی در این دسته‌بندی وجود ندارد.</p>
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var item in Model)
                    {
                        <div class="col-6 col-md-4 col-lg-4">
                            <div class="product-card h-100">

                                <!-- عکس -->
                                <div class="product-img-wrap">
                                    <img src="@Url.Content(item.Url)" alt="@item.Name" class="product-img" />
                                    <div class="product-overlay">
                                        <a asp-controller="Product"
                                           asp-action="ShowProductDetails"
                                           asp-route-id="@item.Id"
                                           class="btn btn-light btn-sm rounded-pill px-3">
                                            مشاهده جزئیات
                                        </a>
                                    </div>
                                </div>

                                <!-- اطلاعات -->
                                <div class="product-body">
                                    <h6 class="product-name fw-bold">@item.Name</h6>
                                    <div class="d-flex justify-content-between align-items-center mt-2">
                                        <span class="product-price text-success fw-bold">
                                            @item.Price.ToString("N0")
                                            <small class="text-muted fw-normal"> تومان</small>
                                        </span>
                                    </div>
                                    <a asp-controller="Cart"
                                       asp-action="AddToCart"
                                       asp-route-Id="@item.Id"
                                       class="btn btn-primary btn-sm w-100 mt-3 rounded-3">
                                        🛒 افزودن به سبد
                                    </a>
                                </div>

                            </div>
                        </div>
                    }
                </div>
            }

        </div>
    </div>
</div>

<style>
    .sidebar-box {
        background: #fff;
        border: 1px solid #eee;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    }

    .product-card {
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(0,0,0,0.07);
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
    }

        .product-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.13);
        }

    .product-img-wrap {
        position: relative;
        overflow: hidden;
        background: #f8f9fb;
        height: 190px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .product-img {
        max-height: 160px;
        object-fit: contain;
        transition: transform 0.3s ease;
    }

    .product-card:hover .product-img {
        transform: scale(1.06);
    }

    .product-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0.35);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .product-card:hover .product-overlay {
        opacity: 1;
    }

    .product-body {
        padding: 14px 16px 18px;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .product-name {
        font-size: 0.92rem;
        color: #222;
        min-height: 2.4rem;
    }

    .product-price {
        font-size: 1rem;
    }
</style>

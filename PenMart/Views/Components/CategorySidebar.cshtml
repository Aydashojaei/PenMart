<div class="category-box">
    <h5 class="category-title">
        دسته‌بندی‌ها
    </h5>

    <ul class="list-unstyled m-0">
        @foreach (var cat in Model)
        {
            <li>
                <a asp-controller="Product"
                   asp-action="ShowProductByCategoryId"
                   asp-route-categoryId="@cat.Id"
                   class="category-link">

                    <span class="category-icon">
                        <i class="bi bi-tag-fill"></i>
                    </span>

                    <span>@cat.CategoryName</span>
                </a>
            </li>
        }
    </ul>
</div>
<style>
    .category-box {
        background: #fff;
        border-radius: 16px;
        padding: 20px;
        border: 1px solid #ececec;
        box-shadow: 0 8px 25px rgba(0,0,0,.06);
    }

    .category-title {
        font-size: 20px;
        font-weight: 700;
        color: #0d6efd;
        margin-bottom: 18px;
        padding-bottom: 10px;
        border-bottom: 2px solid #eef4ff;
    }

    .category-link {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
        color: #444;
        padding: 12px 14px;
        border-radius: 12px;
        margin-bottom: 8px;
        transition: all .25s ease;
    }

        .category-link:hover {
            background: #f5f9ff;
            color: #0d6efd;
            transform: translateX(-4px);
        }

    .category-icon {
        width: 34px;
        height: 34px;
        background: #eaf3ff;
        color: #0d6efd;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .category-link:hover .category-icon {
        background: #0d6efd;
        color: white;
    }

</style>
@model IEnumerable<Category>

<div class="container mt-4">
    <div class="row justify-content-center">
        @foreach (var item in Model)
        {
            <div class="col-md-3 col-sm-6 mb-4">
                <a asp-controller="Product"
                   asp-action="ShowProductByCategoryId"
                   asp-route-categoryId="@item.Id"
                   class="text-decoration-none">

                    <div class="card border-0 shadow-sm rounded-3 overflow-hidden category-card">
                        <img src="@item.Url" class="card-img-top" alt="@item.CategoryName">

                        <div class="card-img-overlay d-flex align-items-end justify-content-center p-0">
                            <p class="card-text bg-dark bg-opacity-25 text-white text-center w-100 m-0 py-2 fs-5 fw-semibold">
                                @item.CategoryName
                            </p>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
</div>

<style>
    /* برای هماهنگی رنگ و جلوه */
    .category-card img {
        object-fit: cover;
        height: 250px;
        transition: transform 0.4s ease, box-shadow 0.3s ease;
    }

    .category-card:hover img {
        transform: scale(1.05);
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
    }

    /* رنگ پس‌زمینه‌ی متن روی عکس */
    .card-text {
        background: rgba(0, 0, 0, 0.3);
        backdrop-filter: blur(3px);
    }
</style>

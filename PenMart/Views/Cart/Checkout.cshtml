@model PenMart.Models.CheckoutViewModel
@{
    ViewData["Title"] = "تکمیل خرید";
    var total = Model.Order?.orderDetails?.Sum(d => d.Count * d.Price) ?? 0;
}

<div class="container my-5">
    <div class="row g-4">

        <!-- فرم اطلاعات -->
        <div class="col-12 col-md-7">
            <div class="checkout-box p-4 rounded-4">
                <h5 class="fw-bold mb-4">📋 اطلاعات تحویل</h5>

                <form asp-action="Checkout" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label fw-semibold"></label>
                        <input asp-for="FullName" class="form-control rounded-3"
                               placeholder="مثال: علی احمدی" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Phone" class="form-label fw-semibold"></label>
                        <input asp-for="Phone" class="form-control rounded-3"
                               placeholder="مثال: 09123456789" />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Address" class="form-label fw-semibold"></label>
                        <textarea asp-for="Address" class="form-control rounded-3" rows="3"
                                  placeholder="استان، شهر، خیابان، پلاک..."></textarea>
                        <span asp-validation-for="Address" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Notes" class="form-label fw-semibold"></label>
                        <textarea asp-for="Notes" class="form-control rounded-3" rows="2"
                                  placeholder="توضیحات اضافه برای سفارش (اختیاری)"></textarea>
                    </div>

                    <button type="submit" class="btn-confirm w-100">
                        ✅ تایید و ثبت سفارش
                    </button>
                </form>
            </div>
        </div>

        <!-- خلاصه سفارش -->
        <div class="col-12 col-md-5">
            <div class="summary-box p-4 rounded-4">
                <h5 class="fw-bold mb-4">🛒 خلاصه سفارش</h5>

                @foreach (var item in Model.Order.orderDetails)
                {
                    <div class="d-flex align-items-center mb-3 summary-item">
                        <img src="@Url.Content(item.product?.MainImageUrl ?? "/Images/no-image.png")"
                             class="summary-img ml-3" alt="@item.product?.Name" />
                        <div class="flex-grow-1">
                            <div class="fw-semibold small">@item.product?.Name</div>
                            <div class="text-muted small">@item.Count عدد × @item.Price.ToString("N0") تومان</div>
                        </div>
                        <div class="fw-bold text-success small">
                            @((item.Count * item.Price).ToString("N0"))
                        </div>
                    </div>
                }

                <hr />

                <div class="d-flex justify-content-between align-items-center">
                    <span class="fw-bold">جمع کل:</span>
                    <span class="total-price">@total.ToString("N0") تومان</span>
                </div>

                <div class="mt-3 text-center">
                    <small class="text-muted">
                        🔒 اطلاعات شما محفوظ است
                    </small>
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    .checkout-box {
        background: #fff;
        border: 1px solid #eee;
        box-shadow: 0 2px 16px rgba(0,0,0,0.07);
    }

    .summary-box {
        background: #f8fafb;
        border: 1px solid #e3eaf0;
        box-shadow: 0 2px 12px rgba(0,0,0,0.05);
        position: sticky;
        top: 90px;
    }

    .summary-img {
        width: 52px;
        height: 52px;
        object-fit: contain;
        border-radius: 8px;
        border: 1px solid #eee;
        background: white;
    }

    .summary-item {
        padding-bottom: 12px;
        border-bottom: 1px dashed #eee;
    }

    .total-price {
        font-size: 1.3rem;
        font-weight: bold;
        color: #2e7d32;
    }

    .btn-confirm {
        display: block;
        background: linear-gradient(135deg, #2e7d32, #43a047);
        color: white;
        border: none;
        padding: 14px;
        border-radius: 12px;
        font-size: 1rem;
        font-weight: bold;
        cursor: pointer;
        transition: all 0.3s;
    }

    .btn-confirm:hover {
        background: linear-gradient(135deg, #1b5e20, #2e7d32);
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(46,125,50,0.35);
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

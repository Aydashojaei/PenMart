@page
@model PenMart.Pages.Admin.ManageProduct.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>لیست محصولات </h1>
<hr />

<div class="container-fluid">
    <div class="row">
        <!-- Main content (لیست محصولات) -->
        <div class="col-md-9 order-md-1 order-2">

            <a asp-page="Create" class="cssbuttons-io-button">
                <span>افزودن محصول</span>
            </a>

            <div class="table-responsive">
                <table class="admin-table text-center table">
                    <thead>
                        <tr>
                            <th>تصویر</th>
                            <th>نام</th>
                            <th>قیمت</th>
                            <th>دستورات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.products)
                        {
                            <tr>
                                <td>
                                    <img src="@item.MainImageUrl" class="admin-img" />
                                </td>
                                <td>@item.Name</td>
                                <td>@item.Item.Price تومان</td>
                                <td>
                                    <a asp-page="Edit" asp-route-id="@item.Id" class="btn-action btn-edit">ویرایش</a>
                                    <a asp-page="Delete" asp-route-id="@item.Id" class="btn-action btn-delete">حذف</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>


    </div>
</div>

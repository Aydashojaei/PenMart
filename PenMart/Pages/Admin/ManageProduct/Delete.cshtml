@page
@model PenMart.Pages.Admin.ManageProduct.CreateModel

@{
    ViewData["Title"] = "افزودن محصول";
}

<h2>افزودن محصول جدید</h2>

<form method="post" enctype="multipart/form-data">

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div style="margin-bottom:12px;">
        <label>نام محصول</label><br />
        <input asp-for="Input.Name" class="form-control" />
        <span asp-validation-for="Input.Name" class="text-danger"></span>
    </div>

    <div style="margin-bottom:12px;">
        <label>قیمت</label><br />
        <input asp-for="Input.Price" class="form-control" />
        <span asp-validation-for="Input.Price" class="text-danger"></span>
    </div>

    <div style="margin-bottom:12px;">
        <label>توضیحات</label><br />
        <textarea asp-for="Input.Discription" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Input.Discription" class="text-danger"></span>
    </div>

    <div style="margin-bottom:12px;">
        <label>موجودی</label><br />
        <input asp-for="Input.QuantityStock" class="form-control" />
        <span asp-validation-for="Input.QuantityStock" class="text-danger"></span>
    </div>

    <div style="margin-bottom:12px;">
        <label>دسته‌بندی</label><br />
        <select asp-for="Input.CategoryId" asp-items="ViewBag.CategoryId" class="form-select">
            <option value="">انتخاب دسته‌بندی</option>
        </select>
        <span asp-validation-for="Input.CategoryId" class="text-danger"></span>
    </div>

    <hr />

    <div style="margin-bottom:12px;">
        <label>تصاویر محصول (حداکثر 4 عکس)</label><br />
        <input asp-for="Input.Images" type="file" class="form-control" accept="image/*" multiple />
        <span asp-validation-for="Input.Images" class="text-danger"></span>
    </div>

    <div style="margin-bottom:12px;">
        <label>انتخاب عکس اصلی</label><br />
        <div id="mainImageOptions"></div>
        <span asp-validation-for="Input.MainImageIndex" class="text-danger"></span>
    </div>

    <div style="margin-bottom:12px;">
        <label>پیش‌نمایش</label><br />
        <div id="previews" style="display:flex; gap:10px; flex-wrap:wrap;"></div>
    </div>

    <button type="submit" class="btn btn-primary">ثبت محصول</button>
    <a asp-page="Index" class="btn btn-secondary">بازگشت</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (function () {
            const fileInput = document.querySelector('input[name="Input.Images"]');
            const previews = document.getElementById('previews');
            const mainOptions = document.getElementById('mainImageOptions');

            function clearUI() {
                previews.innerHTML = '';
                mainOptions.innerHTML = '';
            }

            function render(files) {
                clearUI();

                if (!files || files.length === 0) return;

                if (files.length > 4) {
                    alert('حداکثر 4 عکس می‌توانید انتخاب کنید.');
                    fileInput.value = '';
                    return;
                }

                // گزینه‌های انتخاب عکس اصلی (به تعداد فایل‌های واقعی)
                for (let i = 0; i < files.length; i++) {
                    const idx = i + 1;

                    const label = document.createElement('label');
                    label.style.marginRight = '12px';

                    const radio = document.createElement('input');
                    radio.type = 'radio';
                    radio.name = 'Input.MainImageIndex';
                    radio.value = String(idx);
                    if (idx === 1) radio.checked = true;

                    label.appendChild(radio);
                    label.appendChild(document.createTextNode(' عکس ' + idx));
                    mainOptions.appendChild(label);
                }

                // پیش‌نمایش
                for (let i = 0; i < files.length; i++) {
                    const url = URL.createObjectURL(files[i]);

                    const img = document.createElement('img');
                    img.src = url;
                    img.width = 120;
                    img.height = 120;
                    img.style.objectFit = 'cover';
                    img.style.border = '1px solid #ccc';
                    img.style.borderRadius = '8px';

                    previews.appendChild(img);
                }
            }

            fileInput.addEventListener('change', function () {
                render(this.files);
            });
        })();
    </script>
}
